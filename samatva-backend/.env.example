# ─────────────────────────────────────────────────────────
#  SAMATVA AI — Backend Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────

# Your OpenAI API Key — get it from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Port the server listens on (default: 3001)
PORT=3001

# Allowed frontend origin for CORS (add your deployed URL here when live)
ALLOWED_ORIGIN=*
